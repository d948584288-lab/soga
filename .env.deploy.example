# =====================================
# 生产环境配置示例
# 复制此文件为 .env.deploy 并修改配置
# =====================================

# 数据库配置（⚠️ 务必修改密码）
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://app:your_strong_password_here@postgres:5432/app

# Redis 配置（通常不需要修改）
# REDIS_URL=redis://redis:6379

# API 配置
API_PORT=4000

# CORS 配置
# 方式1：反射模式（IP访问时使用，默认开启）
CORS_REFLECT=1

# 方式2：指定域名（有域名时使用，取消注释并修改）
# CORS_REFLECT=0
# CORS_ORIGIN=https://your-domain.com

# 前端公共 API URL
NEXT_PUBLIC_API_URL=/api

# Nginx 网关端口
# 宝塔已占用 80/443 端口时，修改为其他端口如 8080
HTTP_PORT=8080
MOONSHOT_API_KEY=你的APIKey