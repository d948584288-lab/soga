# Optional overrides on top of deploy/staging.defaults.env
#
# Local full stack (no manual edit required for defaults):
#   pnpm docker:prod
#
# Custom production example:
#   docker compose -f docker-compose.prod.yml \
#     --env-file deploy/staging.defaults.env \
#     --env-file .env.deploy \
#     up -d --build
#
# POSTGRES_PASSWORD=...
# DATABASE_URL=postgresql://app:...@postgres:5432/app
# CORS_ORIGIN=https://your-domain.com
# CORS_REFLECT=0
# HTTP_PORT=80
