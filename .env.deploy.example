# Copy to .env.deploy and adjust for your server (IP-only test env).

# --- Postgres (must match DATABASE_URL credentials) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=app

# Prisma / API — host `postgres` is the Compose service name
DATABASE_URL=postgresql://app:change_this_password@postgres:5432/app

# Browser origin allowed to call the API (no trailing slash)
# 仅 IP 测试示例: http://203.0.113.10
# 若网关映射为 8080: http://203.0.113.10:8080
CORS_ORIGIN=http://REPLACE_WITH_SERVER_IP

# Frontend build-time: same-origin API via Nginx path (recommended)
NEXT_PUBLIC_API_URL=/api

# Host port published by gateway (Nginx). Default 80.
# 若 1Panel 或其它服务已占用 80，可改为 8080，访问 http://IP:8080
HTTP_PORT=80
