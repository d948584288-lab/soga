# Default test/staging stack (used by: pnpm docker:prod)
# Override on the server by editing this file or passing another --env-file after this one.

POSTGRES_USER=app
POSTGRES_PASSWORD=staging_app_change_me
POSTGRES_DB=app

DATABASE_URL=postgresql://app:staging_app_change_me@postgres:5432/app
REDIS_URL=redis://redis:6379

API_PORT=4000
# Reflect browser Origin (any IP/host) — use for IP-only test deploys
CORS_REFLECT=1

NEXT_PUBLIC_API_URL=/api
HTTP_PORT=8080
