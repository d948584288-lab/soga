# Production / Staging 环境配置
# 复制此文件并根据需要修改

# ==================== 数据库配置 ====================
POSTGRES_USER=app
POSTGRES_PASSWORD=staging_app_change_me
POSTGRES_DB=app

DATABASE_URL=postgresql://app:staging_app_change_me@postgres:5432/app
REDIS_URL=redis://redis:6379

# ==================== API 配置 ====================
API_PORT=4000

# CORS 配置
# CORS_REFLECT=1  # 反射任意 Origin（用于 IP 访问）
# 或指定具体域名：
# CORS_ORIGIN=https://your-domain.com
CORS_REFLECT=1

# JWT 配置
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ==================== LLM 配置 ====================
# 月之暗面 Kimi API Key
# 从 https://platform.moonshot.cn/ 获取
MOONSHOT_API_KEY=sk-your-moonshot-api-key

# OpenAI API Key（可选）
OPENAI_API_KEY=sk-your-openai-api-key

# ==================== 前端配置 ====================
NEXT_PUBLIC_API_URL=/api

# ==================== Nginx 配置 ====================
HTTP_PORT=8080

# ==================== Worker 配置 ====================
WORKER_REPLICAS=1
