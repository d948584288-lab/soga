# Copy to apps/api/.env for local dev (see apps/api/.env.example).

DATABASE_URL=postgresql://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379
API_PORT=4000
# Local: http://localhost:3000 — API routes are under /api (e.g. /api/health).
CORS_ORIGIN=http://localhost:3000

# Docker / 1Panel (same machine, IP only): copy .env.deploy.example → .env.deploy
